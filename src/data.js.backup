export const TIPS = {
  education: [
    { title: 'التعلم بالصور والرموز (PECS)', body: 'بطاقات الصور أداة مثبتة علمياً لتطوير التواصل. ابدأ بـ 10 بطاقات لأشياء محبوبة وعلّم طفلك أن يناولك البطاقة ليحصل على ما يريد. الدماغ البصري لأطفال متلازمة داون يستجيب لهذا الأسلوب بقوة ملحوظة.' },
    { title: 'الروتين اليومي المرئي', body: 'جدول مصوَّر بالصور أو الرموز لكل نشاط في اليوم — الاستيقاظ، الفطور، اللعب، النوم. معرفة ما سيأتي بعد ذلك يمنح الطفل شعوراً بالأمان ويقلل القلق والانهيارات العاطفية بشكل ملحوظ جداً.' },
    { title: 'جلسات قصيرة ومكافأة فورية (DTT)', body: 'أسلوب التدريب المتقطع: مهارة واحدة في جلسة لا تتجاوز 10 دقائق مع مكافأة فورية عند كل استجابة صحيحة. الاتساق والتكرار المُبهج هما سر النجاح في هذا الأسلوب المثبت علمياً.' },
    { title: 'التعلم عبر اللعب الحر', body: 'الألعاب التركيبية كالمكعبات والأحجية تطور التخطيط والتسلسل. أدوار اللعب التمثيلي تنمّي اللغة والتعاطف. دمج هدف تعليمي في كل لعبة دون أن يشعر الطفل بأنه في حصة رسمية.' }
  ],
  health: [
    { title: 'الرياضة علاج وفرح في آنٍ معاً', body: 'السباحة هي الرياضة المثلى لأطفال متلازمة داون: تُقوّي كل عضلات الجسم، تُحسّن التوازن والتنسيق، وتُعطي إحساساً رائعاً بالحرية. 30 دقيقة ثلاث مرات أسبوعياً تصنع فارقاً حقيقياً في القوة العضلية والمزاج.' },
    { title: 'الغدة الدرقية — لا تتجاهلها أبداً', body: 'قصور الغدة الدرقية يُصيب 15-20٪ من أطفال متلازمة داون ويؤثر مباشرة على النمو العقلي والجسدي. فحص دوري كل 6 أشهر ضروري حتى لو لم تظهر أعراض. العلاج المبكر يغيّر مسار النمو كلياً.' },
    { title: 'صحة الفم مرتبطة مباشرة بصحة القلب', body: 'التهابات اللثة عند أطفال متلازمة داون يمكن أن تؤثر على القلب عبر البكتيريا التي تدخل مجرى الدم. ابدأ تنظيف الأسنان من أول ضرسة وزر طبيب الأسنان كل 6 أشهر.' },
    { title: 'انقطاع التنفس أثناء النوم — خذه بجدية تامة', body: '60٪ من أطفال متلازمة داون يعانون انقطاعاً في التنفس أثناء النوم. الأعراض: شخير، استيقاظ متكرر، تعب خلال النهار. اطلب دراسة النوم من طبيبك — العلاج يُحسّن التركيز والتعلم بشكل كبير.' }
  ],
  social: [
    { title: 'الدمج المدرسي — التدرج هو المفتاح', body: 'لا تتسرع في الدمج الكامل. ابدأ بساعات محددة في صف الدمج ثم وسّع تدريجياً. بناء علاقة قوية مع المعلمة أهم من كل شيء — اشرح لها نقاط قوة طفلك واحتياجاته، وقدّم أدوات مساعدة للصف.' },
    { title: 'تمثيل الأدوار في البيت يبني مهارات الحياة', body: 'العب مع طفلك مشاهد الحياة اليومية: السلام، طلب المساعدة، الاعتذار، ترتيب الدور. المسرح المنزلي البسيط يرسّخ الأنماط الاجتماعية التي يحتاجها الطفل في المدرسة والحياة بشكل لا تعوّضه أي جلسة علاج.' },
    { title: 'مجموعات اللعب مع أقران متنوعين', body: 'ابحث عن مجموعات لعب تضم أطفالاً من مختلف القدرات. الأطفال ذوو التطور الطبيعي يُعلّمون أطفال متلازمة داون مهارات تقليد اجتماعي لا تستطيع أي جلسة علاج منفردة تعليمها. التفاعل الطبيعي هو العلاج الأفضل.' },
    { title: 'احتفل علناً — بناء الثقة بالنفس', body: 'الاحتفال العلني بكل إنجاز صغير أمام العائلة والأصدقاء يبني صورة إيجابية لدى الطفل عن نفسه. الطفل الذي يعرف أنه محبوب وقادر يجرؤ على التفاعل والمشاركة الاجتماعية بثقة حقيقية.' }
  ],
  personal: [
    { title: 'لا تخجل من مشاعرك الصعبة في البداية', body: 'الخوف والحزن والتساؤل "لماذا أنا؟" مشاعر إنسانية طبيعية ومشروعة تماماً. لا تحاكم نفسك عليها. امنح نفسك وقتاً للتقبّل — الحب لا يُلغي المشاعر الصعبة بل يتعايش معها. وعندما يأتي القبول، سيأتي معه فرح لا تصفه الكلمات.' },
    { title: 'وثّق كل خطوة مهما بدت صغيرة', body: 'أول ابتسامة، أول كلمة، أول خطوة — هذه اللحظات تستحق أن تُحفظ وتُحتفى بها. في اللحظات الصعبة ستعود لتراها وتدرك كم قطعتم من شوط. ريم علّمتني أن الانتصار الحقيقي يُقاس بالخطوات الصغيرة.' },
    { title: 'ابحث عن مجتمع يفهمك فعلاً', body: 'لا شيء يُشبه التحدث مع أب أو أم يعيشون نفس الرحلة. تعلّمت من آباء آخرين أكثر مما تعلّمت من الكتب كلها. هذه المنصة وُلدت من هذه الحاجة الحقيقية — لأن الطريق مع رفيق يفهمك يختلف تماماً عن السير وحدك.' },
    { title: 'طفلك يُعلّمك ما لا تجده في أي مكتبة', body: 'ريم علّمتني معنى الصبر الحقيقي، ومعنى الفرح البسيط، ومعنى أن تحضر في اللحظة كلياً. 17 عاماً من التدريس لم تُعلّمني ما علّمتني إياه ريم في سنواتها الأولى. دع طفلك يكون معلمك الأول والأعمق.' }
  ]
};

